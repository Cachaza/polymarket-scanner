# Copy to .env and edit as needed
POLY_DATABASE_URL=postgresql://polymarket:polymarket@db:5432/polymarket
POLY_DB_USER=polymarket
POLY_DB_PASSWORD=polymarket
POLY_DB_NAME=polymarket
POLY_BACKTEST_CSV_PATH=data/backtest.csv
POLY_LATENT_BACKTEST_CSV_PATH=data/latent_backtest.csv
POLY_REQUEST_TIMEOUT=20
POLY_DISCOVERY_LIMIT=200
POLY_MARKET_LIMIT=250
POLY_HOLDER_LIMIT=20
POLY_HOLDER_MIN_BALANCE=1
POLY_KEYWORD_MODE=keywords
POLY_KEYWORDS=
POLY_TELEGRAM_BOT_TOKEN=
POLY_TELEGRAM_CHAT_ID=
POLY_API_HOST=127.0.0.1
POLY_API_PORT=8000

# Optional Docker Compose / Dokploy overrides
WEB_PORT=3000
POLY_DISCOVER_CRON=0 */6 * * *
POLY_REFRESH_LEADERBOARD_CRON=15 2 * * *
POLY_SNAPSHOT_CRON=*/15 * * * *
POLY_SCORE_ALERTS_CRON=1-59/15 * * * *
POLY_JOB_LOCK_FILE=/tmp/polymarket-scanner.lock
